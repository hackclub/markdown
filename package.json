{
  "name": "@hackclub/markdown",
  "description": "Render Markdown to HTML, Hack Club-style",
  "version": "0.1.2",
  "author": "Lachlan Campbell <lachlan@hackclub.com> (https://lachlanjc.me)",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "src",
    "dist/index.cjs",
    "README.md",
    "LICENSE.md"
  ],
  "sideEffects": false,
  "scripts": {
    "test": "bun test",
    "prepare": "bun build src/index.js --target=node --format=cjs --packages=external --outfile=dist/index.cjs",
    "build": "bun run prepare && cd docs && bun run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hackclub/markdown.git"
  },
  "dependencies": {
    "@mapbox/rehype-prism": "^0.9.0",
    "github-slugger": "^2.0.0",
    "mdast-util-to-string": "^4.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "unified": "^11.0.0",
    "unist-util-remove": "^4.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {}
}
