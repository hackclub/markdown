{
  "name": "@hackclub/markdown",
  "description": "Render Markdown to HTML, Hack Club-style",
  "version": "0.0.43",
  "author": "Lachlan Campbell <lachlan@hackclub.com> (https://lachlanjc.me)",
  "source": "src/index.js",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "unpkg": "dist/index.umd.js",
  "sideEffects": false,
  "scripts": {
    "test": "ava",
    "prepare": "rm -rf ./dist && microbundle --external none --target node",
    "watch": "microbundle watch --no-compress --external none --target node",
    "build": "yarn prepare && cd docs && yarn build"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hackclub/markdown.git"
  },
  "dependencies": {
    "@mapbox/rehype-prism": "^0.9.0",
    "github-slugger": "^2.0.0",
    "mdast-util-to-string": "^4.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "unified": "^11.0.0",
    "unist-util-remove": "^4.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "ava": "^6.0.0",
    "microbundle": "^0.15.0"
  }
}
